  "keyFeatures": [
    "AI-powered bird species identification from audio recordings",
    "Real-time audio recording with high-quality capture settings",
    "Interactive map visualization of bird sightings with geolocation",
    "Comprehensive bird catalog with images and audio samples",
    "User history and analytics dashboard",
    "Role-based access control (admin and researcher roles)",
    "PWA support for mobile and offline capabilities",
    "Species confirmation and correction by users"
  ],
  "publicApiSurface": [
    "POST /v1/auth/login - User authentication",
    "GET /v1/usuarios/me - Get current user information",
    "POST /v1/inferencia/procesar_inferencia - Process audio for bird identification",
    "GET /v1/inferencia/historial - Get user's inference history",
    "GET /v1/inferencia/listar_aves - List all bird species in catalog",
    "POST /v1/inferencia/especie_usuario - Confirm or correct species identification",
    "GET /v1/admin/logs/historial - Get all inference logs (admin only)",
    "AnalizadorAudio component - Audio recording and upload interface",
    "MapaPredicciones component - Interactive map with bird sighting markers",
    "CatalogoAves component - Searchable bird species catalog",
    "ModalResultados component - Display identification results"
  ]
